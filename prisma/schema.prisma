generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(BUYER)
  products  Product[]
  orders    Order[]
  createdAt DateTime  @default(now())
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  imageUrl    String
  latitude    Float
  longitude   Float
  seller      User     @relation(fields: [sellerId], references: [id])
  sellerId    String
  createdAt   DateTime @default(now())
  orders      Order[]
}

model Order {
  id        String      @id @default(uuid())
  buyer     User        @relation(fields: [buyerId], references: [id])
  buyerId   String
  product   Product     @relation(fields: [productId], references: [id])
  productId String
  status    OrderStatus @default(PENDING)
  paymentId String?
  createdAt DateTime    @default(now())
}
